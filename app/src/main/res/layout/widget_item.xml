<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/widget_item_bg"
    android:gravity="center_vertical"
    android:padding="10dp"
    android:layout_marginVertical="2dp">

    <!-- Bullet indicator -->
    <View
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/widget_bullet"
        android:layout_marginEnd="10dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="1">

        <TextView
            android:id="@+id/item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grocery shopping"
            android:textColor="#041E49"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/item_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="At 10:00 AM"
            android:textColor="#64748B"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <TextView
        android:id="@+id/item_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quick"
        android:textColor="#0B57D0"
        android:textSize="9sp"
        android:textStyle="bold"
        android:background="@drawable/widget_category_bg"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp" />

</LinearLayout>
